ORO_USER_RUNTIME={{.UserRuntime}}
ORO_ENV={{if eq .Type "demo"}}prod{{else}}dev{{end}}

# Data for install
ORO_USER_NAME=admin
ORO_USER_PASSWORD=admin
ORO_USER_FIRSTNAME=John
ORO_USER_LASTNAME=Doe
ORO_USER_EMAIL=admin@example.com
ORO_SAMPLE_DATA=y
ORO_ORGANIZATION_NAME=OroInc
ORO_LANGUAGE=en
ORO_FORMATTING_CODE=en_US
# OroCommerce Application URL (Primary domain from index 0)
ORO_APP_PROTOCOL={{if .Domains}}{{with (index .Domains 0)}}{{if .Ssl}}https{{else}}http{{end}}{{end}}{{else}}http{{end}}
ORO_APP_DOMAIN="{{if .Domains}}{{(index .Domains 0).Host}}{{else}}oro.demo{{end}}"
ORO_WEB_HOST=web
ORO_NGINX_HTTP_PORT={{.NginxHTTPPort}}
ORO_INSTALL_OPTIONS=

ORO_MAINTENANCE_LOCK_FOLDER=/tmp/oro-maintenance
ORO_MAINTENANCE_LOCK_FILE_NAME=maintenance_lock
ORO_MAINTENANCE_LOCK_FILE_PATH="${ORO_MAINTENANCE_LOCK_FOLDER}/${ORO_MAINTENANCE_LOCK_FILE_NAME}"

ORO_PHP_FPM_HOST=php-fpm-app
ORO_PHP_FPM_PORT=9000
ORO_CONSUMER_SERVICE=consumer
ORO_PAUSE_SERVICES=php-fpm-app|cron
ORO_RESTART_SERVICES=php-fpm-app|cron|ws
ORO_CONSUMER_XDEBUG_ENABLED=false
ORO_CRON_XDEBUG_ENABLED=false
ORO_INSTALL_XDEBUG_ENABLED=false
ORO_JPEGOPTIM_BINARY='/usr/bin/jpegoptim'
ORO_PNGQUANT_BINARY='/usr/bin/pngquant'
ORO_OPTIPNG_BINARY='/usr/bin/optipng'

# Services version
ORO_PG_VER={{.PostgresVersion}}

ORO_DB_HOST=db
ORO_DB_PORT=5432
ORO_DB_NAME=oro_db
ORO_DB_NAME_TEST=oro_db_test
ORO_DB_USER=oro_db_user
ORO_DB_PASSWORD=oro_db_pass
ORO_DB_DSN="postgres://${ORO_DB_USER}:${ORO_DB_PASSWORD}@${ORO_DB_HOST}:${ORO_DB_PORT}/${ORO_DB_NAME}?sslmode=disable&charset=utf8&serverVersion=${ORO_PG_VER}"
# Used for restore DB from dump
ORO_DB_ROOT_USER=oro_db_user
ORO_DB_ROOT_PASSWORD=oro_db_pass

{{if .RabbitMQ -}}
ORO_MQ_DSN=amqp://guest:guest@rabbitmq:5672/%2f
{{- else -}}
ORO_MQ_DSN=dbal:
{{- end}}
{{if .Redis -}}
ORO_SESSION_DSN=redis://redis:6379/0
{{- else -}}
ORO_SESSION_DSN=native:
{{- end}}
{{if .Elasticsearch -}}
ORO_SEARCH_ENGINE_DSN=elasticsearch:?host=elasticsearch&port=9200
ORO_WEBSITE_SEARCH_ENGINE_DSN=elasticsearch:?host=elasticsearch&port=9200
{{- else -}}
ORO_SEARCH_ENGINE_DSN=orm:?prefix=oro_search
ORO_WEBSITE_SEARCH_ENGINE_DSN=orm:?prefix=oro_website_search
{{- end}}
ORO_MAILER_DSN=smtp://mail:1025
ORO_PDF_GENERATOR_GOTENBERG_API_URL=http://gotenberg:3000
ORO_WEBSOCKET_BACKEND_HOST=ws
ORO_WEBSOCKET_BACKEND_PORT=8080
ORO_WEBSOCKET_SERVER_DSN="//0.0.0.0:${ORO_WEBSOCKET_BACKEND_PORT}"
ORO_WEBSOCKET_FRONTEND_DSN=//*:80/ws
ORO_WEBSOCKET_BACKEND_DSN="tcp://${ORO_WEBSOCKET_BACKEND_HOST}:${ORO_WEBSOCKET_BACKEND_PORT}"

ORO_APP_URL="${ORO_APP_PROTOCOL}://${ORO_APP_DOMAIN}/"

PHP_MEMORY_LIMIT=6096M
