ORO_USER_RUNTIME={{.UserRuntime}}
ORO_ENV=test
ORO_PG_VER={{.PostgresVersion}}

ORO_APP_PROTOCOL="http"
ORO_APP_DOMAIN="localhost"
ORO_APP_URL="http://localhost/"
ORO_INSTALL_OPTIONS=

ORO_DB_PORT=5432
ORO_DB_NAME=oro_db_test
ORO_DB_USER=oro_db_user
ORO_DB_PASSWORD=oro_db_pass
ORO_DB_DSN="postgres://${ORO_DB_USER}:${ORO_DB_PASSWORD}@db:${ORO_DB_PORT}/oro_db_test?sslmode=disable&charset=utf8&serverVersion=${ORO_PG_VER}"

ORO_MAILER_DSN=smtp://mail:1025
ORO_PDF_GENERATOR_GOTENBERG_API_URL=http://gotenberg:3000
ORO_WEBSOCKET_SERVER_DSN=
ORO_WEBSOCKET_FRONTEND_DSN=
ORO_WEBSOCKET_BACKEND_DSN=
